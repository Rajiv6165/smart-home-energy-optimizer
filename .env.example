# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///optimizer.db

# ── Home Location (used for weather forecast) ────────────────────────────────
HOME_LATITUDE=37.7749
HOME_LONGITUDE=-122.4194

# ── Comfort & Tariff ─────────────────────────────────────────────────────────
COMFORT_MIN_C=20.5
COMFORT_MAX_C=23.5
TARIFF_PER_KWH=0.22

# ── Background Task Intervals ─────────────────────────────────────────────────
WEATHER_REFRESH_MINUTES=60
SCHEDULE_REFRESH_MINUTES=90

# ── JWT Authentication ────────────────────────────────────────────────────────
# IMPORTANT: Replace with a strong random 32+ character string in production!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production-use-a-32-char-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
